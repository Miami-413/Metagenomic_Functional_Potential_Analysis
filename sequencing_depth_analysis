import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import glob
import os
import numpy as np

# --- CONFIGURATION ---
input_dir = "/scratch/user/zach.vice/phd_data/beef_pork_data/beef_data/Seq_Stats/histogram"
output_img = "sequencing_depth_boxplot.png"

# Setup Plotting Style
sns.set_theme(style="whitegrid")
plt.figure(figsize=(14, 8))

# --- DATA PROCESSING ---
files = sorted(glob.glob(os.path.join(input_dir, '*.txt')))
all_samples_data = []

if not files:
    print(f"No files found in {input_dir}. Check your path!")
else:
    for f in files:
        sample_name = os.path.basename(f).replace('.txt', '')
        
        try:
            # 1. Load data
            df = pd.read_csv(f, sep='\t', header=None, 
                             names=['contig', 'depth', 'count', 'total', 'prop'],
                             low_memory=False, on_bad_lines='skip')
            
            # 2. Cleanup and Coerce
            df['depth'] = pd.to_numeric(df['depth'], errors='coerce')
            df['count'] = pd.to_numeric(df['count'], errors='coerce')
            df = df.dropna(subset=['depth', 'count'])
            
            # 3. Create a weight-representative sample for the Box Plot
            # Since we have counts, we expand the data to represent the distribution
            # We filter for depths > 0 to avoid plotting zeros on a log scale
            valid_df = df[df['depth'] > 0]
            
            # Create a sample list for plotting. 
            # Note: We take a representative sample if the count is massive to keep it fast
            expanded_depths = np.repeat(valid_df['depth'].values, valid_df['count'].astype(int).values)
            
            # Store in master list
            temp_df = pd.DataFrame({'Depth': expanded_depths, 'Sample': sample_name})
            all_samples_data.append(temp_df)
            
        except Exception as e:
            print(f"Error processing {sample_name}: {e}")

    # Combine all data
    master_df = pd.concat(all_samples_data)

    # --- PLOTTING ---
    sns.boxplot(data=master_df, x='Sample', y='Depth', showfliers=False) # showfliers=False hides extreme outliers
    
    # Log Transformation
    plt.yscale('log')
    
    plt.title('Distribution of Sequencing Depth per Sample', fontsize=16)
    plt.xlabel('Sample', fontsize=12)
    plt.ylabel(r'Sequencing Depth ($\log_{10}$ scale)', fontsize=12)
    plt.xticks(rotation=45, ha='right')
    
    plt.tight_layout()
    plt.savefig('sequencing_depth.pdf', dpi=300, bbox_inches='tight')
    plt.show()
